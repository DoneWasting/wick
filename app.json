{
  "expo": {
    "name": "Wick",
    "slug": "candle-alerts",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "wick",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0E0E"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#1FBF7A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wick.app"
    },
    "android": {
      "package": "com.wick.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0E0E"
      },
      "permissions": [
        "NOTIFICATIONS",
        "POST_NOTIFICATIONS",
        "USE_EXACT_ALARM",
        "SCHEDULE_EXACT_ALARM",
        "WAKE_LOCK",
        "NOTIFICATIONS",
        "POST_NOTIFICATIONS",
        "USE_EXACT_ALARM",
        "SCHEDULE_EXACT_ALARM",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#1FBF7A",
          "sounds": [
            "./assets/sounds/alert.mp3"
          ]
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1ca5ea7f-dc58-453a-97bb-ede8c042eaee"
      }
    },
    "owner": "donewasting",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1ca5ea7f-dc58-453a-97bb-ede8c042eaee"
    }
  }
}
