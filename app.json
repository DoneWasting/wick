{
  "expo": {
    "name": "Candle Alerts",
    "slug": "candle-alerts",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "candlealerts",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0e14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.candlealerts.app"
    },
    "android": {
      "package": "com.candlealerts.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0a0e14"
      },
      "permissions": [
        "NOTIFICATIONS",
        "POST_NOTIFICATIONS",
        "USE_EXACT_ALARM",
        "SCHEDULE_EXACT_ALARM",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#4a90e2",
          "sounds": ["./assets/sounds/alert.mp3"]
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1ca5ea7f-dc58-453a-97bb-ede8c042eaee"
      }
    },
    "owner": "donewasting"
  }
}
